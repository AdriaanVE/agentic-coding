#!/bin/bash
# Preview files in the terminal using markitdown + glow
# Markdown files go straight to glow; everything else through markitdown first.

if [ -z "$1" ]; then
  echo "Usage: preview <file>"
  exit 1
fi

file="$1"

if [ ! -f "$file" ]; then
  echo "File not found: $file"
  exit 1
fi

case "${file##*.}" in
  md|markdown)
    glow -p "$file"
    ;;
  *)
    markitdown "$file" | glow -p
    ;;
esac
